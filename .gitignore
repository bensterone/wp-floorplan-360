# =============================================================================
# wp-floorplan-360 — .gitignore
# =============================================================================


# --- Node / Build tooling ---
node_modules/


# --- WordPress core & environment ---
# If you're developing inside a local WordPress install,
# ignore everything except your own plugin folder.
# (Remove these if your repo root IS the plugin folder.)
wp-admin/
wp-includes/
wp-content/uploads/
wp-content/plugins/
wp-content/themes/
wp-config.php
wp-config-local.php
wp-cli.phar
.htaccess


# --- Compiled / generated assets ---
# Built JS is kept in git so users can install without running npm.
# Source maps are dev-only artifacts — exclude them from the repo.
# Webpack 5 emits dynamic-import and Web Worker chunks as separate files
# (e.g. src_editor_dxf_index_js.editor.js). Whitelist all *.editor.js so
# those chunks are committed alongside editor.js.
assets/js/*.map
assets/js/*.js
!assets/js/editor.js
!assets/js/*.editor.js
!assets/js/block-editor.js
!assets/js/aframe.min.js
!assets/js/viewer.js

# --- A-Frame binary ---
# Large vendored binary — keep it if you want the repo self-contained,
# remove this line if you commit it (recommended for easy installation).
# assets/js/aframe.min.js


# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini


# --- Editor / IDE ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace


# --- Logs & temp ---
*.log
*.tmp
*.bak
*.swp


# --- Environment files ---
.env
.env.local


# --- Composer (not used yet, but common in WP projects) ---
vendor/
composer.lock