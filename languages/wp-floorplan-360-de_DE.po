msgid "Floorplan 360 Viewer"
msgstr "Grundriss 360°-Viewer"

#. Description of the plugin
#: wp-floorplan-360.php
msgid "Interactive floorplans with polygon hotspots and 360° room viewer."
msgstr ""
"Interaktive Grundrisse mit polygonalen Hotspots und 360° Raumbetrachter."

#. Author of the plugin
#: wp-floorplan-360.php
msgid "Ben Sturm / WBG Zentrum eG"
msgstr "Ben Sturm / WBG Zentrum eG"

#: includes/Admin/Assets.php:28
msgid "Pick 360"
msgstr "360° auswählen"

#: includes/Admin/Assets.php:29 views/meta-box.php:10
msgid "Select Floorplan Image"
msgstr "Grundriss-Bild auswählen"

#: includes/Admin/Assets.php:30
msgid "Delete Room"
msgstr "Raum löschen"

#: includes/Admin/Assets.php:31
msgid "Delete this room?"
msgstr "Diesen Raum löschen?"

#: includes/Admin/Assets.php:32
msgid "New Room"
msgstr "Neuer Raum"

#: includes/Admin/Assets.php:33
msgid "Room Label"
msgstr "Raum Label"

#: includes/Admin/Assets.php:34
msgid "Detect Rooms"
msgstr "Räume erkennen"

#: includes/Admin/Assets.php:35
msgid "Detecting…"
msgstr "Erkennung..."

#: includes/Admin/Assets.php:36
msgid "Detected {n} room(s). Review polygons and assign 360° images."
msgstr "{n} Räume erkannt. Bitte Polygone prüfen und 360° Bild zuordnen."

#: includes/Admin/Assets.php:37
msgid ""
"No rooms detected. Try a lower sensitivity value, or draw rooms manually."
msgstr ""
"Keine Räume erkannt. Sensitivität verringern oder Räume manuell zeichnen."

#: includes/Admin/Assets.php:38
msgid "Please upload a floorplan image first."
msgstr "Bitte Grundriss hochladen."

#: includes/Admin/Assets.php:39
msgid "Detection failed. Please draw rooms manually."
msgstr "Erkennung gescheitert. Bitte Räume manuell zeichnen."

#: includes/Admin/Assets.php:40
msgid "Clear existing rooms and re-detect?"
msgstr "Alle Räume löschen und neu erkennen?"

#: includes/Admin/Assets.php:41
msgid "Delete all rooms? This cannot be undone until you save."
msgstr ""
"Alle Räume löschen? Kann nicht rückgängig gemacht werden bis zum "
"Speichern."

#: includes/Admin/Assets.php:42
msgid "Clear All Rooms"
msgstr "Alle Räume löschen"

#: includes/Admin/Assets.php:43 views/meta-box.php:75
msgid "Seed Rooms"
msgstr "Seed Räume"

#: includes/Admin/Assets.php:44
msgid "✕ Cancel Seed Mode"
msgstr "✕ Abbrechen"

#: includes/Admin/Assets.php:45
msgid "Click once inside each room, then click Run Fill."
msgstr "In einzelne Räume klicken. Dann Füllen."

#: includes/Admin/Assets.php:46 views/meta-box.php:79
msgid "Run Fill"
msgstr "Füllen"

#: includes/Admin/Assets.php:47 views/meta-box.php:83
msgid "Clear Seeds"
msgstr "Alle löschen"

#: includes/Admin/Assets.php:48 views/meta-box.php:37
msgid "Rectangle"
msgstr "Rechteck"

#: includes/Admin/Assets.php:49
msgid "✕ Cancel Rectangle"
msgstr "✕ Rechteck abbrechen"

#: includes/Admin/Assets.php:50 views/meta-box.php:41
msgid "Polygon"
msgstr "Polygon"

#: includes/Admin/Assets.php:51
msgid "✕ Cancel Polygon"
msgstr "✕ Polygon abbrechen"

#: includes/Admin/Assets.php:52 views/meta-box.php:45
msgid "Merge"
msgstr "Zusammenführen"

#: includes/Admin/Assets.php:53
msgid "Rooms must overlap or share an edge to merge."
msgstr ""
"Räume müssen überlappen oder sich eine Kante teilen, um zusammengeführt "
"werden zu können."

#: includes/Admin/Assets.php:54
msgid "Cancel"
msgstr "Abbrechen"

#: includes/Admin/Assets.php:55
msgid "OK"
msgstr "OK"

#: includes/Admin/Editor.php:13
msgid "Floorplan Editor"
msgstr "Grundriss Editor"

#: includes/Admin/Editor.php:22
msgid "Viewer Settings"
msgstr "Betrachter Einstellungen"

#: includes/Admin/Editor.php:61
msgid "Auto-rotate panorama"
msgstr "Auto-Rotation Panorama"

#: includes/Admin/Editor.php:66
msgid "Active room colour:"
msgstr "Aktiver Raum Farbe:"

#: includes/Admin/Editor.php:74
msgid "Colour of the selected room polygon"
msgstr "Farbe des ausgewählten Polygons"

#: includes/Admin/Editor.php:79
msgid "Panorama start angle:"
msgstr "Ausgangswinkel:"

#: includes/Admin/Editor.php:88
msgid "Horizontal rotation when panorama first loads (-180 to 180)"
msgstr "Horizontale Ausgangssicht bei Laden des Panoramas (-180 bis 180)"

#: includes/Block/Block.php:70 includes/Frontend/Assets.php:20
msgid "View room"
msgstr "Raum anzeigen"

#: includes/Block/Block.php:71 includes/Frontend/Assets.php:21
msgid "No 360° image assigned to this room."
msgstr "Kein 360°-Bild diesem Raum zugewiesen."

#: includes/Block/Block.php:72 includes/Frontend/Assets.php:22
msgid "The 360° image could not be loaded."
msgstr "Das 360°-Bild konnte nicht geladen werden."

#: includes/Core/PostType.php:16 includes/Core/PostType.php:21
msgid "Floorplans"
msgstr "Grundrisse"

#: includes/Core/PostType.php:17
msgid "Floorplan"
msgstr "Grundriss"

#: includes/Core/PostType.php:18
msgid "Add New"
msgstr "Neu hinzufügen"

#: includes/Core/PostType.php:19
msgid "Edit Floorplan"
msgstr "Grundriss bearbeiten"

#: includes/Core/PostType.php:20
msgid "Search Floorplans"
msgstr "Grundrisse suchen"

#: templates/block-viewer.php:33 templates/floorplan-template.php:34
msgid "No floorplan image uploaded."
msgstr "Kein Grundriss-Bild hochgeladen."

#: templates/block-viewer.php:40 templates/floorplan-template.php:39
msgid "360 degree room view"
msgstr "360 Grad Raumansicht"

#: templates/block-viewer.php:43 templates/floorplan-template.php:41
msgid "Select a room on the floorplan to view it in 360°"
msgstr "Klicken Sie auf einen Raum im Grundriss für die 360°-Ansicht"

#: templates/block-viewer.php:46 templates/floorplan-template.php:44
msgid "Loading viewer..."
msgstr "Lade Betrachter..."

#: templates/block-viewer.php:53 templates/floorplan-template.php:52
msgid "360 degree room viewer"
msgstr "360°-Raumviewer"

#: templates/block-viewer.php:59 templates/floorplan-template.php:58
msgid "Room list"
msgstr "Liste der Räume"

#: views/iframe-viewer.php:42
msgid "360° viewing is not supported by your browser or device."
msgstr ""
"360° Ansichten werden von Ihrem Browser oder Gerät nicht unterstützt."

#: views/iframe-viewer.php:43
msgid ""
"WebGL is required. Try a modern desktop browser such as Chrome or Firefox."
msgstr ""
"WebGL wird benötigt. Bitte modernen Browser wie z.B. Chrome oder Firefox "
"benutzen."

#: views/iframe-viewer.php:46
msgid "Loading Panorama..."
msgstr "Lade Panorama..."

#: views/iframe-viewer.php:50
msgid "JavaScript is required to view 360° panoramas."
msgstr "JavaScript wird benötigt um 360°-Panoramas anzuzeigen."

#: views/meta-box.php:4
msgid "Floorplan Image"
msgstr "Grundriss Bild"

#: views/meta-box.php:9
msgid "Change Image"
msgstr "Bild ändern"

#: views/meta-box.php:17
msgid "Floorplan preview will appear here."
msgstr "Grundriss Vorschau wird hier angezeigt."

#: views/meta-box.php:49
msgid "Undo"
msgstr "Rückgängig"

#: views/meta-box.php:53
msgid "Clear All"
msgstr "Alle löschen"

#: views/meta-box.php:61
msgid "Experimental"
msgstr "Experimentell"

#: views/meta-box.php:69
msgid ""
"These tools use automatic image analysis and may not work reliably on all "
"floorplans. Manual drawing is always the fallback."
msgstr ""
"Experimentelle Werkzeuge benutzen automatische Bilderkennung und könnten "
"nicht zuverlässig funktionieren. Manuelles Zeichnen wird empfohlen."

#: views/meta-box.php:90
msgid "Auto-Detect"
msgstr "Erkennung"

#: views/meta-box.php:93
msgid "Sensitivity:"
msgstr "Sensitivität:"

#: views/meta-box.php:106
msgid "Rooms & 360° Views"
msgstr "Räume & 360° Ansichten"

#: views/meta-box.php:108
msgid "Rectangle:"
msgstr "Rechteck:"

#: views/meta-box.php:109
msgid "Drag over a room — edges snap to walls automatically."
msgstr ""
"Über Raum ziehen - Kanten richten sich automatisch an den Wänden aus."

#: views/meta-box.php:110
msgid "Polygon:"
msgstr "Polygon:"

#: views/meta-box.php:111
msgid "Click to place points, double-click to close."
msgstr "Klick zum platzieren, Doppel-Klick zum schließen."

#: views/meta-box.php:112
msgid "Shift-click two rooms then Merge for L-shapes."
msgstr "Shift-Klick auf zwei Räume um sie L-förmig zusammenzuführen."

#: views/meta-box.php:116
msgid "Pro Tip:"
msgstr "Pro Tip:"

#: views/meta-box.php:117
msgid "Double-click the last point to quickly close a polygon shape."
msgstr ""
"Doppelklick auf den letzten Punkt, um eine Raumform schnell zu schließen."

#: wp-floorplan-360.php:24
msgid ""
"Floorplan 360 Viewer requires PHP 7.4 or higher. Please upgrade PHP or "
"contact your hosting provider."
msgstr "Grundriss 360°-Viewer erfordert PHP 7.4 oder höher..."

#: assets/js/block-editor.js:1 src/block-editor.js:30
msgid "— Select a Floorplan —"
msgstr "— Grundriss auswählen —"

#: assets/js/block-editor.js:1 src/block-editor.js:32
msgid "(no title)"
msgstr "(no title)"

#: assets/js/block-editor.js:1 src/block-editor.js:58
msgid "No floorplans found. Create one under Floorplans > Add New first."
msgstr ""
"Keine Grundrisse gefunden. Bitte zuerst einen unter Grundrisse > Neu "
"hinzufügen erstellen."

#: assets/js/block-editor.js:1 src/block-editor.js:71
msgid "Floorplan Settings"
msgstr "Grundriss-Einstellungen"

#: assets/js/block-editor.js:1 src/block-editor.js:73
msgid "Select Floorplan"
msgstr "Grundriss auswählen"

#: assets/js/block-editor.js:1 src/block-editor.js:87
msgid "Choose a floorplan from the block settings panel on the right."
msgstr "Wählen Sie einen Grundriss im Einstellungsbereich rechts aus."
